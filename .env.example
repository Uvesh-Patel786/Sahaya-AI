# Environment template — Sahayak AI
# Copy to .env and fill in secrets. Never commit real keys.

NODE_ENV=development

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/sahayak

# Services
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:5173
AI_SERVICE_URL=http://localhost:8000
CHROMA_URL=http://localhost:8001

# Gemini
GEMINI_API_KEY=sk-4UMeKpYpSIHCQYS79amYoZFAslMffMpXIOIIQdKWPTWG79L6+
GEMINI_MODEL=google/gemma-3-12b-it

# Uploads
